{
  "expo": {
    "name": "Rahaa Eats",
    "slug": "rahaa-eats",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "rahaa",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/images/branding/logo-white.png",
      "resizeMode": "contain",
      "backgroundColor": "#4CAF50"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Rahaa uses your location to find restaurants near you and to set your delivery address.",
        "NSPhotoLibraryUsageDescription": "Rahaa needs access to your photos so you can set a profile picture."
      },
      "bundleIdentifier": "com.anonymous.rahaa-eats"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-dev-client",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Rahaa uses your location to find restaurants near you and to set your delivery address."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Rahaa needs access to your photos so you can set a profile picture."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
